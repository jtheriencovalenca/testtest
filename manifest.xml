<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <!-- ═══════════════════════════════════════════════════
       IDENTITY
       Replace the GUID below with a new one for your org.
       Generate one at: https://guidgenerator.com
  ═══════════════════════════════════════════════════ -->
  <Id>a1b2c3d4-e5f6-7890-abcd-ef1234567890</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Your Organisation</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Email Templates" />
  <Description DefaultValue="Insert pre-approved email templates from SharePoint directly into Outlook." />

  <!-- Icon shown in Outlook ribbon -->
  <IconUrl DefaultValue="https://via.placeholder.com/32" />
  <HighResolutionIconUrl DefaultValue="https://via.placeholder.com/64" />

  <!-- Required: where Outlook fetches support info -->
  <SupportUrl DefaultValue="https://jtheriencovalenca.github.io/testtest/taskpane.html" />

  <!-- ═══════════════════════════════════════════════════
       HOST REQUIREMENTS
       This add-in requires Outlook (not Word, Excel, etc.)
  ═══════════════════════════════════════════════════ -->
  <Hosts>
    <Host Name="Mailbox" />
  </Hosts>

  <Requirements>
    <Sets>
      <!-- Mailbox 1.3+ supports body.setAsync() which we use for HTML insertion -->
      <Set Name="Mailbox" MinVersion="1.3" />
    </Sets>
  </Requirements>

  <!-- ═══════════════════════════════════════════════════
       DEFAULT SETTINGS
       The URL of your task pane page.
       Host this file anywhere Outlook can reach it:
         - SharePoint / SPO
         - Azure Static Web Apps (free tier)
         - GitHub Pages
  ═══════════════════════════════════════════════════ -->
  <DefaultSettings>
    <SourceLocation DefaultValue="https://jtheriencovalenca.github.io/testtest/taskpane.html" />
  </DefaultSettings>

  <!-- Permissions: ReadWriteItem lets us set subject + body -->
  <Permissions>ReadWriteItem</Permissions>

  <!-- When to activate: only in Compose mode (new email / reply) -->
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit" />
  </Rule>

  <!-- ═══════════════════════════════════════════════════
       VERSION OVERRIDES
       Controls the ribbon button in modern Outlook
  ═══════════════════════════════════════════════════ -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides"
                    xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.3">
        <bt:Set Name="Mailbox" />
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>

          <!-- Function file (not needed for task pane only add-ins) -->
          <FunctionFile resid="FunctionFile.Url" />

          <!-- ── Compose message extension point ── -->
          <ExtensionPoint xsi:type="MessageComposeCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="EmailTemplatesGroup">
                <Label resid="GroupLabel" />

                <!-- Ribbon button that opens the task pane -->
                <Control xsi:type="Button" id="OpenTemplatesPane">
                  <Label resid="PaneButton.Label" />
                  <Supertip>
                    <Title resid="PaneButton.Label" />
                    <Description resid="PaneButton.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16" />
                    <bt:Image size="32" resid="Icon.32x32" />
                    <bt:Image size="80" resid="Icon.80x80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>ButtonId1</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url" />
                  </Action>
                </Control>

              </Group>
            </OfficeTab>
          </ExtensionPoint>

        </DesktopFormFactor>
      </Host>
    </Hosts>

    <!-- ═════════════════════════════════════
         RESOURCES — all string/URL references
    ═════════════════════════════════════ -->
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://via.placeholder.com/16" />
        <bt:Image id="Icon.32x32" DefaultValue="https://via.placeholder.com/32" />
        <bt:Image id="Icon.80x80" DefaultValue="https://via.placeholder.com/80" />
      </bt:Images>

      <bt:Urls>
        <bt:Url id="FunctionFile.Url"  DefaultValue="https://jtheriencovalenca.github.io/testtest/taskpane.html" />
        <bt:Url id="Taskpane.Url"      DefaultValue="https://jtheriencovalenca.github.io/testtest/taskpane.html" />
      </bt:Urls>

      <bt:ShortStrings>
        <bt:String id="GroupLabel"         DefaultValue="Templates" />
        <bt:String id="PaneButton.Label"   DefaultValue="Email Templates" />
      </bt:ShortStrings>

      <bt:LongStrings>
        <bt:String id="PaneButton.Tooltip" DefaultValue="Open the Email Templates panel to insert a pre-approved template." />
      </bt:LongStrings>
    </Resources>

  </VersionOverrides>

</OfficeApp>